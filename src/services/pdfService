import jsPDF from 'jspdf';
import autoTable from 'jspdf-autotable';
import { ENSINAR_CAMOES_LOGO, ENSINAR_SAUDE_LOGO } from '../assets/logos-pdfs';

export const gerarDiarioBordoPDF = (dadosFormacao, listaAtividades) => {
  const doc = new jsPDF();
  const pageWidth = doc.internal.pageSize.getWidth();
  const pageHeight = doc.internal.pageSize.getHeight();

  // --- LÓGICA DE DISTRIBUIÇÃO POR SLOTS (MAX 5 POR PÁGINA) ---
  const paginasDeAtividades = [];
  let paginaAtual = [];
  let slotsUsados = 0;

  listaAtividades.forEach((act) => {
    // Se a descrição for maior que 280, ocupa 2 slots, caso contrário 1
    const peso = (act.descricao && act.descricao.length > 280) ? 2 : 1;

    // Se o peso da atividade não couber nos slots restantes da página (max 5)
    if (slotsUsados + peso > 5) {
      // Preenchemos o resto da página com linhas vazias antes de criar nova
      while (slotsUsados < 5) {
        paginaAtual.push({ data: '', atividade: '', descricao: '', peso: 1 });
        slotsUsados++;
      }
      paginasDeAtividades.push(paginaAtual);
      paginaAtual = [];
      slotsUsados = 0;
    }

    paginaAtual.push({ ...act, peso });
    slotsUsados += peso;
  });

  // Preencher a última página se necessário para manter as 5 linhas visuais
  while (slotsUsados < 5 && slotsUsados > 0) {
    paginaAtual.push({ data: '', atividade: '', descricao: '', peso: 1 });
    slotsUsados++;
  }
  if (paginaAtual.length > 0) paginasDeAtividades.push(paginaAtual);

  // Se não houver atividades, garantir pelo menos uma página vazia
  if (paginasDeAtividades.length === 0) {
    paginasDeAtividades.push(Array(5).fill({ data: '', atividade: '', descricao: '', peso: 1 }));
  }

  const totalPaginas = paginasDeAtividades.length;

  const desenharEstruturaFixa = (numeroPagina) => {
    // 1. O NIF NA MARGEM ESQUERDA (Coordenadas originais preservadas)
    doc.setFontSize(6);
    doc.setTextColor(150);
    doc.text("N.I.F. 515 675 836", 10, 235, { angle: 90 });

    // 2. LOGOTIPO SUPERIOR
    doc.addImage(ENSINAR_SAUDE_LOGO, 'PNG', 3, 10, 60, 50);

    // 3. TÍTULO CENTRALIZADO
    doc.setFont("helvetica", "bold");
    doc.setFontSize(12);
    doc.text("DIÁRIO DE BORDO – FORMAÇÃO ESPECIALIZADA", pageWidth / 2, 62, { align: "center" });

    // 4. TABELA DE IDENTIFICAÇÃO (Estilos e larguras originais preservados)
    autoTable(doc, {
      startY: 68,
      theme: 'grid',
      styles: { fontSize: 8, cellPadding: 1, lineColor: [0, 0, 0], lineWidth: 0.3 },
      body: [
        [{ content: 'ESPECIALIDADE', fontStyle: 'bold' }, { content: dadosFormacao.especialidade || '', colSpan: 2 }],
        [{ content: 'TUTOR(A)', fontStyle: 'bold' }, { content: dadosFormacao.tutor || '', colSpan: 2 }],
        [
          { content: 'FORMANDO(A)', fontStyle: 'bold' },
          { content: dadosFormacao.formando || '' },
          { content: `Hospital de Origem: ${dadosFormacao.hospitalOrigem || ''}` }
        ],
        [
          { content: 'PERÍODO', fontStyle: 'bold' },
          { content: dadosFormacao.periodo || '' },
          { content: `Horário: ${dadosFormacao.horario || ''}` }
        ],
        [{ content: 'LOCAL FORMAÇÃO', fontStyle: 'bold' }, { content: dadosFormacao.local || '', colSpan: 2 }],
        [{ content: 'UNIDADE', fontStyle: 'bold' }, { content: dadosFormacao.unidade || '', colSpan: 2 }],
      ],
      columnStyles: {
        0: { cellWidth: 30 },
        1: { cellWidth: 55 },
        2: { cellWidth: 75 }
      },
      margin: { left: 25, right: 25 }
    });

    // 5. RODAPÉ (Posições originais preservadas)
    const footerY = pageHeight - 20;
    doc.setFontSize(9);
    doc.setTextColor(0);
    doc.text(`Folha nº ${numeroPagina}/${totalPaginas}`, pageWidth - 40, pageHeight - 56, { align: 'right' });

    doc.addImage(ENSINAR_SAUDE_LOGO, 'PNG', 5, footerY - 25, 30, 25);
    doc.addImage(ENSINAR_CAMOES_LOGO, 'PNG', pageWidth - 47, footerY - 20, 40, 20);

    doc.setFontSize(5);
    const info = "ENSINAR SAÚDE NORTE – ASSOCIAÇÃO PARA O ENSINO, INVESTIGAÇÃO E DESENVOLVIMENTO DOS PROFISSIONAIS DE SAÚDE\nRUA DA MATA, Nº 180 | 4480-565 TOUGUINHÓ - VILA DO CONDE | TEL: (+351) 252 097 700";
    doc.text(info, pageWidth / 2, pageHeight - 45, { align: "center" });
  };

  // --- CICLO DE GERAÇÃO DAS PÁGINAS ---
  paginasDeAtividades.forEach((atividadesDaPagina, i) => {
    if (i > 0) doc.addPage();
    desenharEstruturaFixa(i + 1);

    autoTable(doc, {
      startY: 108,
      head: [['DATA', 'ATIVIDADE', 'DESCRIÇÃO/ OBSERVAÇÃO DA ATIVIDADE', 'ASSINATURA TUTOR(A)']],
      body: atividadesDaPagina.map(act => [act.data, act.atividade, act.descricao, '']),
      theme: 'grid',
      styles: {
        fontSize: 7,
        minCellHeight: 23, // Altura base para 1 slot
        valign: 'middle',
        lineColor: [0, 0, 0],
        lineWidth: 0.1
      },
      headStyles: {
        fillColor: [210, 210, 210],
        textColor: [0, 0, 0],
        halign: 'center',
        fontStyle: 'bold',
        cellPadding: 1.5,
        minCellHeight: 0
      },
      columnStyles: {
        0: { cellWidth: 25, halign: "center" },
        1: { cellWidth: 35, halign: "center" },
        2: { cellWidth: 75 },
        3: { cellWidth: 25 }
      },
      margin: { left: 25, right: 25 },

      // APLICAÇÃO DA LÓGICA DE ALTURA DINÂMICA POR LINHA
      didParseCell: function (data) {
        if (data.section === 'body') {
          const rowIndex = data.row.index;
          const item = atividadesDaPagina[rowIndex];
          if (item && item.peso === 2) {
            // Se a descrição for longa, a linha ganha o dobro da altura (23 * 2)
            data.row.height = 46;
          }
        }
      }
    });
  });

  doc.save("Diario_Bordo_Final.pdf");
};